rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 200; }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'pickedCardsHistory', 'lastPickedDate', 'lastMissionId'])
        && data.displayName is string && data.displayName.size() <= 256
        && data.pickedCardsHistory is list && data.pickedCardsHistory.size() <= 100
        && data.lastPickedDate is string && data.lastPickedDate.size() <= 50
        && data.lastMissionId is string && data.lastMissionId.size() <= 50;
    }

    function isValidDailyDeck(data) {
      return data.keys().hasAll(['date', 'pickedCardIds'])
        && data.date is string && data.date.size() <= 50
        && data.pickedCardIds is list && data.pickedCardIds.size() <= 100;
    }

    match /daily_decks/{deckDate} {
      allow read: if isSignedIn() && isValidId(deckDate);
      allow create: if isSignedIn()
                    && isValidId(deckDate)
                    && isValidDailyDeck(incoming())
                    && incoming().date == deckDate;
      allow update: if isSignedIn()
                    && isValidId(deckDate)
                    && isValidDailyDeck(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['pickedCardIds', 'date']);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && isValidId(userId)
                    && isValidUser(incoming());
      allow update: if isSignedIn()
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'pickedCardsHistory', 'lastPickedDate', 'lastMissionId']);
    }
  }
}
